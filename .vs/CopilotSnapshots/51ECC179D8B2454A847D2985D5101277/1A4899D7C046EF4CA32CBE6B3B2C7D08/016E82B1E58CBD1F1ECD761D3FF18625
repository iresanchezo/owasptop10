function renderCWEList() {
  cweList.innerHTML = '';
  if (!selectedCategory) return;
  selectedCategory.cwes.forEach(cwe => {
    const li = document.createElement('li');
    li.textContent = `${cwe} - ${owaspLLM.cwes[cwe] || ''}`;
    cweList.appendChild(li);
  });
}

